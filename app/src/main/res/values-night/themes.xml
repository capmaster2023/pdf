<resources>
    <style name="Theme.PDFPocketLite" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="Theme.PDFPocketLite.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#101218</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PDFPocketLite</item>
    </style>
</resources>
